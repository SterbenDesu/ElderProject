NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Google Maps JavaScript API key (Places + Geocoding + Marker).
# Publishable browser key — restrict it to your domain(s) on the Google side.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Optional Google Maps Map ID. AdvancedMarkerElement (the marketplace price
# pins) needs a vector map / Map ID. Leave blank to use Google's public
# DEMO_MAP_ID; set a real Map ID for production styling control.
NEXT_PUBLIC_GOOGLE_MAPS_MAP_ID=
